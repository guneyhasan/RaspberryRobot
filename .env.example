OPENAI_API_KEY=sk-your-key-here
MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o
TTS_VOICE=spruce
MAX_TOKENS=200
TIMEOUT_SECONDS=8
PICOVOICE_ACCESS_KEY=

# Wyoming openWakeWord (ayrı sunucu). Örnek: WYOMING_OPENWAKEWORD_URI=tcp://127.0.0.1:10400
# Boş bırak: sadece transkript wake (kanka / cihan / hey robot).
WYOMING_OPENWAKEWORD_URI=
# Virgülle model adları; boş = sunucu varsayılanı (genelde okay_nabu). Özel .tflite tabanı: my_word
WYOMING_WAKE_NAMES=

PORCUPINE_KEYWORD_PATH=
PORCUPINE_BUILTIN_KEYWORD=computer

# whisper.cpp: ikili kökte `main` veya `build/bin/whisper-cli` olabilir; boş bırakırsanız otomatik aranır.
# WHISPER_BINARY=/home/USER/RaspberryRobot/whisper.cpp/build/bin/whisper-cli
# WHISPER_MODEL=/home/USER/RaspberryRobot/whisper.cpp/models/ggml-small.bin
AUDIO_INPUT_ALSA_DEVICE=plughw:3,0
WAKE_PHRASES=kanka,hey kanka
SILENCE_END_SEC=0.6
VAD_THRESHOLD=0.45

