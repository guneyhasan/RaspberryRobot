OPENAI_API_KEY=sk-your-key-here
MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o
TTS_VOICE=spruce
MAX_TOKENS=200
TIMEOUT_SECONDS=8
PICOVOICE_ACCESS_KEY=

# Alternatif LLM: Groq Cloud (OpenAI yoksa otomatik kullanılır)
# İkisi de doluysa LLM_PROVIDER ile seç: openai | groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_STREAM=0
GROQ_TEMPERATURE=0.6
GROQ_TOP_P=1
LLM_PROVIDER=

# Wake kelimesi zorunluluğunu geliştirme için kapat: 0/1
REQUIRE_WAKE_PHRASE=1

# Konuşma modu: hey kanka ile aç, görüşürüz kanka ile kapat
CONVERSATION_ACTIVATE_PHRASES=hey kanka
CONVERSATION_DEACTIVATE_PHRASES=görüşürüz kanka,gorusuruz kanka

# ALSA mic device override (arecord -D). Ör: plughw:3,0
AUDIO_INPUT_ALSA_DEVICE=

# ALSA hoparlör device override (aplay -D). Ör: hb veya plughw:0,0
AUDIO_OUTPUT_ALSA_DEVICE=

# Piper modelini doğrudan seçmek istersen (opsiyonel)
PIPER_MODEL_PATH=

# Wyoming openWakeWord (ayrı sunucu). Örnek: WYOMING_OPENWAKEWORD_URI=tcp://127.0.0.1:10400
# Boş bırak: sadece transkript wake (kanka / cihan / hey robot).
WYOMING_OPENWAKEWORD_URI=
# Virgülle model adları; boş = sunucu varsayılanı (genelde okay_nabu). Özel .tflite tabanı: my_word
WYOMING_WAKE_NAMES=

PORCUPINE_KEYWORD_PATH=
PORCUPINE_BUILTIN_KEYWORD=computer

# whisper.cpp: ikili kökte `main` veya `build/bin/whisper-cli` olabilir; boş bırakırsanız otomatik aranır.
# WHISPER_BINARY=/home/USER/RaspberryRobot/whisper.cpp/build/bin/whisper-cli
# WHISPER_MODEL=/home/USER/RaspberryRobot/whisper.cpp/models/ggml-small.bin
AUDIO_INPUT_ALSA_DEVICE=plughw:3,0
WAKE_PHRASES=kanka,hey kanka
SILENCE_END_SEC=0.2
VAD_THRESHOLD=0.45
WHISPER_THREADS=4
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_STREAM=0
GROQ_TEMPERATURE=0.6
GROQ_TOP_P=1



